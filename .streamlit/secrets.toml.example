# Copy to .streamlit/secrets.toml (git-ignored) or set as env vars.

# Windsor.ai — ad platforms, GA4, Instagram. (Destinations → API in Windsor.)
WINDSOR_API_KEY = "your-windsor-api-key"

# Shopify Admin API — sales, orders, discount-code attribution. Reached DIRECTLY
# (not via Windsor). Create a custom app in Shopify admin with read_orders scope.
SHOPIFY_SHOP = "your-store.myshopify.com"
SHOPIFY_ACCESS_TOKEN = "shpat_xxx"
